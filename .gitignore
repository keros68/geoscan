# Python
__pycache__/
*.py[cod]
.venv*/
*.egg-info/
.pytest_cache/
build/
dist/

# Editor / IDE local config
.vscode/
.idea/

# Dev-session scratch (temp exports, run logs — never deliverables)
*.log
/output/
/tmp/

# Machine-local settings / secrets — never commit
mapgis_settings.json
mapgis_ai_key.dat
*.pem
*.key
signing_key*
versions.json
.env
.env.*

# Third-party GDAL bundle (regenerated by release scripts, not committed)
packaging/gdal_bundle/
gdal/

# Owner map data must never enter the repo (defense-in-depth backstop)
*.tif
*.tiff
*.jpg
*.jpeg
*.png
*.bmp
*.WL
*.WT
*.WP
*.mpj
*.MPJ
*.dxf
*.geojson
*.onnx
*.db
NONAME.*

# ...but the tiny SECTION bootstrap resource IS part of the program
!src/geoscan/section_bootstrap/SECTION_BOOTSTRAP.WT

# Local-only development files (kept on the developer's machine, never published)
# are excluded via .git/info/exclude so their names don't appear in this repo.
